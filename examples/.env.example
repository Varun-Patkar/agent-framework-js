# ---------------------------------------------------------------------------
# Backend examples only. Copy this file to `.env` inside the workspace you run
# (or keep it here and the backend examples load it from `../../.env`).
#
# The FRONTEND examples never read this file — in the browser the user must
# paste their own GitHub Copilot token into the UI (we cannot ship a secret to
# untrusted clients).
# ---------------------------------------------------------------------------

# GitHub Copilot token. Used ONLY by the backend examples, server-side, and is
# never logged or sent to the browser. Leave blank if you only use LM Studio.
COPILOT_TOKEN=

# Copilot model to request (one the framework's Copilot provider can reach).
COPILOT_MODEL=gpt-5-mini

# LM Studio assumes you have it running locally with a model loaded.
# Default OpenAI-compatible endpoint for LM Studio:
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=local-model

# Remote (HTTP) calculator MCP server used by all examples.
MCP_HTTP_URL=https://calculator.caseyjhand.com/mcp
